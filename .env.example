# ===== CodeReader AI Setup =====
#
# To enable AI-powered explanations (free!):
#
# 1. Go to: https://github.com/settings/tokens?type=beta
# 2. Click "Generate new token"
# 3. Name it "CodeReader"
# 4. Under Permissions, expand "Account permissions" and set "Models" to "Read"
# 5. Click "Generate token" and copy it below
#
# Without this, CodeReader still works — it uses smart code analysis instead.
# With AI, explanations are more conversational and detailed.
#
CODEREADER_GITHUB_TOKEN=your_token_here

# ===== GitHub OAuth (required for login) =====
# Create an OAuth App at: https://github.com/settings/developers
# Set callback URL to: http://localhost:3420/auth/github/callback
#
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
SESSION_SECRET=generate_a_random_secret_here
GITHUB_CALLBACK_URL=http://localhost:3420/auth/github/callback

# ===== Storage (local dev only) =====
# Where to store the SQLite database. Defaults to the project directory.
# DATA_DIR=./

